---
import type { CollectionEntry } from 'astro:content';
import getMainImage from '../../utils/getMainImage';
import CoverImage from '../images/CoverImage.astro';

type Props = {
    article: CollectionEntry<"articles">,
}

const { article } = Astro.props;
const { data, slug } = article;
const { title, images } = data;

const mainImage = getMainImage(images);
---

<article class="bg-gray-600 rounded-sm h-max">
    <div class="flex flex-col items-start gap-4 p-4">
        <h2 class="text-2xl font-bold">{title}</h2>
        <a href={`/articulos/vida-extraterrestre/${slug}`} class="bg-blue-500 px-4 py-2 rounded-md transition-colors hover:bg-blue-700 hover:cursor-pointer">
            <button type="button" class="hover:cursor-pointer">Ver artículo</button>
        </a>
    </div>
    {
        mainImage && (
            <CoverImage image={mainImage} title={`Imagen del artículo ${title}`}/>
        )
    }
</article>