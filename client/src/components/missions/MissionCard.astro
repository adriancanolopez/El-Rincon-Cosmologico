---
import type { CollectionEntry } from 'astro:content';
import CoverImage from '../images/CoverImage.astro';

type Props = {
    mission: CollectionEntry<"missions">,
    link: string,
}

const { mission, link } = Astro.props;

const { title, objective, images } = mission.data;

const mainImage = images?.filter((image) => image.main)[0];
---

<article class="w-full h-max md:w-[45%] flex flex-col gap-4 bg-gray-700 rounded-sm">
    <div class="flex flex-col items-start gap-3 p-4">
        <h3 class="text-2xl font-bold">{title}</h3>
        <p>{objective}</p>
        <a href={link} class="bg-blue-500 px-4 py-2 rounded-md transition-colors hover:bg-blue-700">
            <button class="hover:cursor-pointer">Ver misión</button>
        </a>
    </div>
    {
        mainImage && (
            <CoverImage image={mainImage} title={`Imagen de la misión ${title}`}/>
        )
    }
</article>