---
import AlertIcon from "../../../assets/icons/triangle-alert.svg";
---

<dialog class="m-auto bg-white text-black shadow-lg shadow-gray-400 border-2 border-gray-400 rounded-lg" id="confirm-popup">
    <div class="flex flex-col justify-between items-center gap-2 px-12 py-8">
        <AlertIcon class="text-amber-300"/>
        <h3 class="text-lg text-center font-semibold" id="confirm-title">Confirmar acción</h3>
        <p class="text-center" id="confirm-message"></p>
        <div class="flex flex-row justify-center space-x-4 mt-4">
            <button class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-sm hover:cursor-pointer" id="confirm-btn">Confirmar</button>
            <button class="bg-gray-300 hover:bg-gray-400 px-4 py-2 rounded-sm hover:cursor-pointer" id="cancel-btn">Cancelar</button>
        </div>
    </div>
</dialog>

<script>
    import setupPopupClosing from "../../../scripts/admin/popups/setupPopupClosing";

    setupPopupClosing("confirm-popup", "cancel-btn");
</script>