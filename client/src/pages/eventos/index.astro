---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import getSortedEvents from "../../scripts/events/getSortedEvents";
import EventTypeCard from "../../components/events/EventTypeCard.astro";
import EventCard from "../../components/events/EventCard.astro";

const eventTypes = await getCollection("event-types");
const events = await getCollection("events");
const sortedEvents = getSortedEvents(events);
---

<Layout title="Eventos astronómicos">
    <main class="flex flex-col items-center gap-8 mt-4">
        <h2 class="text-2xl font-bold text-center">Eventos astronómicos</h2>
        <section class="flex flex-col items-center gap-4 px-4 md:px-8">
            <h3 class="text-xl text-center">Tipos de eventos astronómicos</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {
                    eventTypes.map((eventType) => {
                        return (
                            <EventTypeCard eventType={eventType}/>
                        )
                    })
                }
            </div>
        </section>
        <section class="flex flex-col items-center gap-4 px-4 md:px-8">
            <h3 class="text-xl text-center">Próximos eventos astronómicos</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {
                    sortedEvents.map((event) => {
                        return (
                            <EventCard event={event} showTypeLabel hasBackground/>
                        )
                    })
                }
            </div>
        </section>
    </main>
</Layout>