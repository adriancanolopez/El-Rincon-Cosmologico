---
import Layout from '../layouts/Layout.astro';
import '../styles/news.css';
import { getNewsPublished } from '../api/NewsRequests';
import NewsCard from '../components/news/NewsCard.astro';
import { getCollection } from 'astro:content';
import getSortedEvents from '../scripts/events/getSortedEvents';
import EventCard from '../components/events/EventCard.astro';

const newsRequest = await getNewsPublished(4);

const allNews = newsRequest.ok ? newsRequest.data : [];

const events = await getCollection("events");
const sortedEvents = getSortedEvents(events, 4);

---

<Layout title="El Rincón Cosmológico">
	<section class="flex flex-col items-center gap-8 px-4 py-6">
        <h2 class="section-title">Últimas Novedades</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8" id="news">
            {
                allNews.map(news => {
                    return (
                        <NewsCard news={news}/>
                    )
                })
            }
        </div>
        <a href="/noticias" class="yellow-button ml-auto">Ver más noticias</a>
    </section>
    <section class="w-full flex flex-col items-center gap-4 bg-slate-800 px-4 py-8">
        <h2 class="section-title">Próximos eventos astronómicos</h2>
        <div class="relative w-full md:w-3/4" id="events-timeline">
            {
                sortedEvents.map((event) => {
                    return (
                        <div class="relative w-full md:w-1/2 md:odd:left-0 md:even:left-1/2 odd:bg-gray-600 even:bg-gray-500 mb-4 rounded-sm md:rounded-none event">
                            <EventCard event={event} showTypeLabel={true}/>
                        </div>
                    )
                })
            }
        </div>
        <div class="w-full md:w-3/4 flex flex-row justify-center">
            <a href="/eventos" class="yellow-button">Ver todos los próximos eventos</a>
        </div>
    </section>
</Layout>

<style>
    @media screen and (min-width: 768px) {
        #events-timeline::after {
            content: '';
            position: absolute;
            width: 6px;
            background-color: white;
            top: 0;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
        }

        .event:nth-child(odd)::after, .event:nth-child(even)::after {
            content: '';
            position: absolute;
            top: 0%;
            bottom: 0;
            width: 17px;
            height: 17px;
            background-color: white;
            border-radius: 50%;
        }

        .event:nth-child(odd)::after {
            right: 0px;
            transform: translateX(50%);
        }

        .event:nth-child(even)::after {
            left: 0px;
            transform: translateX(-50%);
        }
    }
</style>